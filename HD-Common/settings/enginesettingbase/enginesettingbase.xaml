<controls:UserControl
	x:Class="BlueStacks.Common.EngineSettingBase"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:BlueStacks.Common"
	xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
	FontFamily="pack://siteoforigin:,,,/Assets/#PIXY"
	TextElement.FontFamily="pack://siteoforigin:,,,/Assets/#PIXY">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="pack://application:,,,/HD-Common;component/UIElements/CustomSlider.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/HD-Common;component/UIElements/CustomScrollBar.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/HD-Common;component/UIElements/CustomHyperlinkStyle.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<local:EnumToVisibilityConverter
				x:Key="enumToVisibilityConverter" />
			<local:BooleansToInverseVisibilityConverter2
				x:Key="booleansToInverseVisibilityConverter2" />
			<local:BooleanToVisibilityConverter2
				x:Key="booleanToVisibilityConverter" />
			<local:BooleanToVisibilityConverter3
				x:Key="booleanToVisibilityConverter3" />
			<local:EnumToBoolConverter2
				x:Key="enumToBoolConverter" />
			<Style
				x:Key="ImageStyle"
				TargetType="{x:Type local:CustomPictureBox}">
				<Setter
					Property="Grid.Column"
					Value="0" />
				<Setter
					Property="Margin"
					Value="10,5,4,5" />
				<Setter
					Property="Width"
					Value="20" />
				<Setter
					Property="Height"
					Value="20" />
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid>
		<Grid.Background>
			<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
				<GradientStop Color="#2A2A2A" Offset="0" />
				<GradientStop Color="#202020" Offset="0.5" />
				<GradientStop Color="#151515" Offset="1" />
			</LinearGradientBrush>
		</Grid.Background>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="*" />
			<RowDefinition
				Height="Auto" />
		</Grid.RowDefinitions>
		<StackPanel>
			<DockPanel
				LastChildFill="False"
				Background="#FF402F"
				Height="30"
				Visibility="{Binding Status, Converter='{StaticResource enumToVisibilityConverter}', ConverterParameter='{x:Static local:Status.Error}'}">
				<Label
					FontSize="12"
					HorizontalAlignment="Stretch"
					HorizontalContentAlignment="Left"
					Foreground="#FFFFFFFF"
					FontWeight="Normal"
					Margin="30,0,0,0"
					Content="{Binding ErrorMessage}" />
				<local:CustomButton
					DockPanel.Dock="Right"
					FontSize="11"
					Foreground="#FFFFFFFF"
					Background="#E91F22"
					VerticalAlignment="Center"
					Margin="5"
					Style="{x:Null}"
					Content="{Binding Path=LocaleModel.[STRING_LEARN_MORE], FallbackValue='Learn more', Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
			</DockPanel>
			<Label
				Height="30"
				Padding="30,0,0,0"
				Background="#F09200"
				FontSize="12"
				HorizontalAlignment="Stretch"
				HorizontalContentAlignment="Left"
				VerticalContentAlignment="Center"
				Foreground="#FFFFFFFF"
				Visibility="{Binding Status, Converter='{StaticResource enumToVisibilityConverter}', ConverterParameter='{x:Static local:Status.Warning}'}"
				Content="{Binding WarningMessage}" />
			<StackPanel
				Orientation="Horizontal"
				Background="#757B9F"
				Height="30"
				Visibility="{Binding Status, Converter='{StaticResource enumToVisibilityConverter}', ConverterParameter='{x:Static local:Status.Progress}'}">
				<local:CustomPictureBox
					Margin="30,3,3,3"
					Grid.Column="1"
					ImageName="loader"
					IsImageToBeRotated="True" />
				<Label
					FontSize="12"
					HorizontalAlignment="Stretch"
					HorizontalContentAlignment="Left"
					Foreground="#FFFFFFFF"
					FontWeight="Normal"
					Margin="10,0,0,0"
					Content="{Binding ProgressMessage}" />
			</StackPanel>
		</StackPanel>
		<ScrollViewer
			Grid.Row="1"
			HorizontalScrollBarVisibility="Disabled"
			VerticalScrollBarVisibility="Auto"
			ScrollChanged="ScrollViewer_ScrollChanged">
			<UIElement.OpacityMask>
				<LinearGradientBrush
					StartPoint="0,0"
					EndPoint="0,1">
					<GradientStop
						Color="Transparent"
						Offset="0" />
					<GradientStop
						Color="#FF000000"
						Offset=".15" />
					<GradientStop
						Color="#FF000000"
						Offset=".8" />
					<GradientStop
						Color="Transparent"
						Offset="1" />
				</LinearGradientBrush>
			</UIElement.OpacityMask>
			<StackPanel
				Margin="30,10,20,10">
				<StackPanel>
					<!--<TextBlock
						FontWeight="Normal"
						HorizontalAlignment="Left"
						FontSize="16"
						Text="{Binding Path=LocaleModel.[STRING_PERFORMANCE], FallbackValue=Performance, Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
						Foreground="{Binding Path=ColorModel.[SettingsWindowTabMenuItemLegendForeground], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />-->
					<StackPanel
						Margin="0,5,0,0"
						Orientation="Horizontal">
						<TextBlock
							FontWeight="Normal"
							HorizontalAlignment="Left"
							Margin="0,0,10,0"
							VerticalAlignment="Center"
							FontSize="16"
							Text="{Binding Path=LocaleModel.[STRING_CPU], FallbackValue=CPU, Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
						<local:CustomComboBox
							MinHeight="32"
							MinWidth="162"
							HorizontalAlignment="Left"
							MaxDropDownHeight="200"
							FontSize="15"
							DisplayMemberPath="DisplayText"
							ItemsSource="{Binding CPUList}"
							SelectedValue="{Binding SelectedCPU, Mode=TwoWay}" />
						<TextBlock
							FontWeight="Normal"
							HorizontalAlignment="Left"
							Margin="20,0,10,0"
							FontSize="16"
							VerticalAlignment="Center"
							Text="{Binding Path=LocaleModel.[STRING_RAM], FallbackValue=RAM, Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
						<local:CustomComboBox
							MinHeight="32"
							MinWidth="162"
							HorizontalAlignment="Left"
							MaxDropDownHeight="200"
							FontSize="15"
							DisplayMemberPath="DisplayText"
							ItemsSource="{Binding RamList}"
							SelectedValue="{Binding SelectedRAM, Mode=TwoWay}" />
					</StackPanel>
					<StackPanel
						Margin="0,0,0,0"
						Orientation="Horizontal"
						Visibility="{Binding CustomPerformanceSettingVisibility, Converter='{StaticResource booleanToVisibilityConverter}'}">
						<TextBlock
							TextWrapping="WrapWithOverflow"
							MaxWidth="140"
							FontSize="16"
							VerticalAlignment="Center"
							Margin="0,10,0,0"
							Visibility="{Binding CpuCoreCustomListVisibility, Converter='{StaticResource booleanToVisibilityConverter3}'}"
							Text="{Binding Path=LocaleModel.[STRING_CPU_CORES], FallbackValue='CPU cores', Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
						<local:CustomComboBox
							Height="32"
							MinWidth="120"
							Margin="10,10,0,0"
							HorizontalAlignment="Left"
							MaxDropDownHeight="200"
							FontSize="15"
							Visibility="{Binding CpuCoreCustomListVisibility, Converter='{StaticResource booleanToVisibilityConverter3}'}"
							SelectedItem="{Binding CpuCores}"
							ItemsSource="{Binding CpuCoresList}" />
						<StackPanel
							Margin="20,10,0,0"
							Width="280"
							Visibility="{Binding CustomRamVisibility, Converter='{StaticResource booleanToVisibilityConverter3}'}">
							<DockPanel
								LastChildFill="False">
								<StackPanel
									DockPanel.Dock="Left"
									Orientation="Horizontal">
									<TextBlock
										HorizontalAlignment="Left"
										FontWeight="Normal"
										FontSize="16"
										VerticalAlignment="Bottom"
										RenderTransformOrigin="0.064,0.395"
										Text="{Binding Ram, FallbackValue=600}"
										Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
								</StackPanel>
								<TextBlock
									DockPanel.Dock="Right"
									FontSize="12"
									VerticalAlignment="Bottom"
									Text="{Binding RecommendedRamText, FallbackValue='Recommended 4096'}"
									Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimDimDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
							</DockPanel>
							<Slider
								IsSnapToTickEnabled="True"
								TickFrequency="8"
								IsMoveToPointEnabled="True"
								Orientation="Horizontal"
								Style="{StaticResource CustomSlider}"
								LargeChange="0"
								Margin="0,5,0,0"
								Width="280"
								HorizontalAlignment="Right"
								Value="{Binding Ram}"
								IsEnabled="{Binding IsRamSliderEnabled}"
								Minimum="{Binding MinRam}"
								Maximum="{Binding MaxRam}" />
							<DockPanel
								LastChildFill="False">
								<TextBlock
									DockPanel.Dock="Left"
									HorizontalAlignment="Left"
									FontSize="12"
									Text="{Binding MinRam, FallbackValue=600}"
									Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
								<TextBlock
									DockPanel.Dock="Right"
									FontSize="12"
									Text="{Binding MaxRam, FallbackValue=4096}"
									Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
							</DockPanel>
						</StackPanel>
					</StackPanel>
				</StackPanel>
				<StackPanel
					Margin="0,15,0,0">
					<!--<TextBlock
						Grid.Row="11"
						FontWeight="Normal"
						FontSize="16"
						Text="{Binding Path=LocaleModel.[STRING_FRAME_RATE_SETTING], FallbackValue='Frame Rate Setting', Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
						Foreground="{Binding Path=ColorModel.[SettingsWindowTabMenuItemLegendForeground], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />-->
					<Grid
						Margin="0,5,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="145" />
							<ColumnDefinition
								Width="*" />
						</Grid.ColumnDefinitions>
						<TextBlock
							TextWrapping="WrapWithOverflow"
							FontSize="16"
							MinWidth="140"
							Text="{Binding Path=LocaleModel.[STRING_FPS], FallbackValue=FPS, Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
						<StackPanel
							Grid.Column="1">
							<TextBlock
								DockPanel.Dock="Left"
								HorizontalAlignment="Left"
								FontWeight="Normal"
								FontSize="16"
								Text="{Binding FrameRate, FallbackValue=30}"
								Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
							<Slider
								IsSnapToTickEnabled="True"
								TickFrequency="1"
								IsMoveToPointEnabled="True"
								Orientation="Horizontal"
								Style="{StaticResource CustomSlider}"
								LargeChange="0"
								Margin="0,5,0,0"
								Minimum="1"
								Value="{Binding FrameRate}"
								Maximum="{Binding MaxFPS}"
								IsEnabled="{Binding IsFrameRateEnabled}" />
							<DockPanel
								LastChildFill="False">
								<TextBlock
									DockPanel.Dock="Left"
									HorizontalAlignment="Left"
									Text="1"
									FontSize="11"
									Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
								<TextBlock
									DockPanel.Dock="Right"
									FontSize="11"
									Text="{Binding MaxFPS, FallbackValue=60}"
									Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
							</DockPanel>
						</StackPanel>
					</Grid>
					<StackPanel Orientation="Horizontal" Margin="0,10,0,0">
						<local:CustomCheckbox
							MaxHeight="27"
							FontSize="12"
							HorizontalAlignment="Left"
							IsChecked="{Binding EnableHighFrameRates}"
							Visibility="{Binding IsAndroidBooted, Converter='{StaticResource booleanToVisibilityConverter}'}"
							Content="{Binding Path=LocaleModel.[STRING_ENABLE_HIGH_FPS], FallbackValue='Enable High FPS', Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
						<local:CustomCheckbox
							MaxHeight="27"
							FontSize="12"
							Margin="20,0,0,0"
							HorizontalAlignment="Left"
							IsChecked="{Binding DisplayFPS}"
							Visibility="{Binding IsAndroidBooted, Converter='{StaticResource booleanToVisibilityConverter}'}"
							Content="{Binding Path=LocaleModel.[STRING_DISPLAY_FPS_DURING_GAMEPLAY], FallbackValue='Show FPS', Source='{x:Static local:BlueStacksUIBinding.Instance}'}" />
						<local:CustomCheckbox
							MaxHeight="27"
							FontSize="12"
							Margin="20,0,0,0"
							HorizontalAlignment="Left"
							IsChecked="{Binding EnableAdb}"
							Visibility="{Binding IsAndroidBooted, Converter='{StaticResource booleanToVisibilityConverter}'}"
							Content="Enable ADB" />
					</StackPanel>
					<Grid Margin="0,12,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
							<local:CustomCheckbox
								MaxHeight="27"
								FontSize="12"
								IsChecked="{Binding AutoLockFps}"
								Visibility="{Binding IsAndroidBooted, Converter='{StaticResource booleanToVisibilityConverter}'}"
								Content="АВТО ЛОК" />
						</StackPanel>
						<TextBox
							Grid.Column="1"
							Width="60"
							Height="36"
							Margin="10,0,0,0"
							HorizontalAlignment="Left"
							VerticalContentAlignment="Center"
							HorizontalContentAlignment="Center"
							FontSize="15"
							Background="Transparent"
							Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							BorderBrush="{Binding Path=ColorModel.[SettingsWindowForegroundDimDimDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							Text="{Binding AutoLockFpsText, UpdateSourceTrigger=PropertyChanged}"
							Visibility="{Binding AutoLockFps, Converter='{StaticResource booleanToVisibilityConverter}'}" />
					</Grid>
					<Grid Margin="0,12,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
							<local:CustomCheckbox
								MaxHeight="27"
								FontSize="12"
								IsChecked="{Binding AutoUnlockEnabled}"
								Visibility="{Binding IsAndroidBooted, Converter='{StaticResource booleanToVisibilityConverter}'}"
								Content="АВТО АНЛОК" />
						</StackPanel>
						<TextBox
							Grid.Column="1"
							Width="140"
							Height="36"
							Margin="10,0,0,0"
							HorizontalAlignment="Left"
							VerticalContentAlignment="Center"
							HorizontalContentAlignment="Center"
							FontSize="15"
							IsReadOnly="True"
							Background="Transparent"
							Foreground="{Binding Path=ColorModel.[SettingsWindowForegroundDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							BorderBrush="{Binding Path=ColorModel.[SettingsWindowForegroundDimDimDimColor], Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
							Text="{Binding AutoUnlockKeyText, UpdateSourceTrigger=PropertyChanged}"
							PreviewKeyDown="AutoUnlockKeyBox_PreviewKeyDown"
							Visibility="{Binding AutoUnlockEnabled, Converter='{StaticResource booleanToVisibilityConverter}'}" />
					</Grid>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
		<Grid
			Grid.Row="2"
			Margin="0">
			<local:CustomButton
				Height="45"
				HorizontalAlignment="Stretch"
				Content="{Binding Path=LocaleModel.[STRING_SAVE], FallbackValue=Save, Source='{x:Static local:BlueStacksUIBinding.Instance}'}"
				Command="{Binding SaveCommand}" />
		</Grid>
	</Grid>
</controls:UserControl>
