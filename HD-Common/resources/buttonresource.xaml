	<Style
		x:Key="ProgressBarStyle"
		TargetType="{x:Type ProgressBar}">
		<Setter
			Property="Foreground"
			Value="#FFFF0000" />
		<Setter
			Property="Background"
			Value="#FF0000FF" />
		<Setter
			Property="BorderThickness"
			Value="0" />
		<Setter
			Property="Height"
			Value="5" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type ProgressBar}">
					<Border
						BorderThickness="0"
						CornerRadius="0"
						Padding="0"
						Background="{Binding Path=ColorModel.[ProgressBarBackgroundColor]}">
						<Grid
							x:Name="PART_Track">
							<Rectangle
								x:Name="PART_Indicator"
								HorizontalAlignment="Left"
								Fill="{Binding Path=ColorModel.[ProgressBarProgressColor]}" />
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>
