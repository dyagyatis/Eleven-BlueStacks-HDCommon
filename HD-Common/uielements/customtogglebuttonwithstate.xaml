<controls:UserControl
	x:Class="BlueStacks.Common.CustomToggleButtonWithState"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:BlueStacks.Common"
	x:Name="mCustomToggleButton"
	Height="19"
	Width="60"
	xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<local:BooleanToImageNameConverter
				x:Key="BooleanToImageNameConverter" />
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid
		VerticalAlignment="Center">
		<Grid.ColumnDefinitions>
			<ColumnDefinition
				Width="Auto" />
			<ColumnDefinition
				Width="8" />
			<ColumnDefinition
				Width="*" />
		</Grid.ColumnDefinitions>
		<local:CustomPictureBox
			PreviewMouseLeftButtonUp="mToggleButton_PreviewMouseLeftButtonUp"
			Grid.Column="0"
			Width="32"
			Height="16"
			ImageName="{Binding BoolValue, Converter='{StaticResource BooleanToImageNameConverter}', ConverterParameter=ToggleOn|ToggleOff, RelativeSource={RelativeSource FindAncestor, AncestorType=local:CustomToggleButtonWithState}}" />
		<TextBlock
			Grid.Column="2"
			VerticalAlignment="Stretch"
			Foreground="{Binding Path=ColorModel.[SettingsWindowTabMenuItemLegendForeground]}"
			Text="{Binding BoolValue, Converter='{StaticResource BooleanToImageNameConverter}', ConverterParameter=On|Off, RelativeSource={RelativeSource FindAncestor, AncestorType=local:CustomToggleButtonWithState}}" />
	</Grid>
</controls:UserControl>
